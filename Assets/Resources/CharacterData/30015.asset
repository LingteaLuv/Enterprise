  characterName: "\uB808\uC628 \uD558\uBC84\uC2A4"
  flavorText: "\u201C\uADC0\uCC2E\uB124\u2026 \uADF8\uB0E5 \uD55C \uBC88\uC5D0 \uB05D\uB0B4\uC790.\u201D"
  instruction: "\uC6A9\uBCD1 \uC2DC\uC808\uBD80\uD130 \uAC80 \uD55C \uC790\uB8E8\uB85C
    \uC218\uB9CE\uC740 \uC804\uC7A5\uC744 \uD5E4\uCCD0\uC628 \uC2E4\uB825\uC790.
    \uADC0\uCC2E\uC544\uD558\uB294 \uD0DC\uB3C4\uB85C \uC778\uD574 \uC790\uC8FC \uB098\uD0DC\uD574
    \uBCF4\uC774\uC9C0\uB9CC, \uB9C9\uC0C1 \uC804\uD22C\uAC00 \uC2DC\uC791\uB418\uBA74
    \uB204\uAD6C\uBCF4\uB2E4 \uBE60\uB974\uACE0 \uAC15\uD558\uAC8C \uC801\uC744 \uC81C\uC555\uD55C\uB2E4.
    \uBA39\uACE0\uC0AC\uB294 \uBB38\uC81C\uB85C \uD574\uAD70\uC5D0 \uB4E4\uC5B4\uC654\uC73C\uBA70,
    \uC804\uD22C\uAC00 \uB05D\uB098\uBA74 \uB2E4\uC2DC \uBB34\uAE30 \uC190\uC5D0\uC11C
    \uB0B4\uB824\uB193\uACE0 \uD734\uC2DD\uC744 \uC990\uAE30\uB294 \uAC8C \uC77C\uC0C1\uC774\uB2E4.
    \uB3D9\uB8CC\uB4E4 \uC0AC\uC774\uC5D0\uC11C\uB294 \u201C\uAC8C\uC73C\uB978 \uAC80\uC0AC\u201D\uB77C\uB294
    \uBCC4\uBA85\uC73C\uB85C \uBD88\uB9B0\uB2E4."
