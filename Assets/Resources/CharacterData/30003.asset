  characterName: "\uB3C4\uB85C LONG"
  flavorText: "\u201C\uB3C4\uB85C \uAD50\uD1B5\uACF5\uC0AC\uC5D0\uC11C \uB098\uC654\uC2B5\uB2C8\uB2E4!
